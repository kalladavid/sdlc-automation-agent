# Environment Configuration Example
# Copy this file to .env and fill in with your values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# GitHub Configuration
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO_OWNER=your-organization
GITHUB_REPO_NAME=your-repository
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# AWS Resources (set after CDK deployment)
RESULTS_TABLE_NAME=sdlc-automation-results
ARTIFACTS_BUCKET_NAME=sdlc-automation-artifacts
ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:sdlc-alerts

# Agent Configuration
SECURITY_ENABLED=true
CODE_REVIEW_ENABLED=true
COMPLIANCE_ENABLED=true
RISK_DETECTION_ENABLED=true

# Compliance Frameworks to Check
COMPLIANCE_FRAMEWORKS=SOC2,GDPR,HIPAA,PCI_DSS

# Quality Thresholds
MIN_CODE_QUALITY_SCORE=80
MAX_RISK_SCORE=50

# Logging
LOG_LEVEL=INFO
